{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_dfg_harness": {
    "version": "0.1.0",
    "project_name": "tool-fabric",
    "active_wave": "W1",
    "comment": "Generated by `dfg-harness instrument`. Edit settings.local.json for operator-specific overrides; do not hand-edit this file (regenerated on instrument --update). Hook scripts referenced below are W1-2 deliverables — passive log-only stubs until each lands. Each event-log.sh invocation honours kit/SCHEMAS/hook-cli.schema.json (env-var contract). DFG_EVENT_TYPE is set explicitly only where the hook event maps unambiguously to a single canonical events.schema.json type (Compaction, GateCheck, HitlIntervention, Edit, TaskDispatch, TaskComplete). For PostToolUse and WorktreeCreate the env var is intentionally omitted — these hook events fire across multiple tool-call shapes and the per-tool semantic mapping belongs to the W2 hook scripts (W2-1..W2-4), not this passive template; under PASSIVE=1 the script defaults DFG_EVENT_TYPE to 'Edit' (same behaviour as the W1 status quo), so this is a no-op reconciliation, not a semantic regression."
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh label create:*)",
      "Bash(gh label list:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git worktree list)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv sync:*)",
      "Bash(uv build)",
      "Bash(make:*)",
      "Bash(dfg-harness:*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "kit/hooks/session-start.py", "timeout": 30 },
          { "type": "command", "command": "setsid sh -c 'nohup python3 scripts/producers/session-tail.py --root . </dev/null >/dev/null 2>&1 &' || true", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=HitlIntervention kit/hooks/event-log.sh", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=Edit kit/hooks/event-log.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=TaskDispatch kit/hooks/event-log.sh", "timeout": 5 },
          { "type": "command", "command": "PASSIVE=1 kit/hooks/contract-issue-validation.py", "timeout": 30 }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gh pr merge:*)",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/pre-merge-hold-check.py", "timeout": 30 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/event-log.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "if": "Edit(kit/METHODOLOGY/**)|Edit(kit/HITL-ARCHETYPES/**)|Edit(kit/ANTI-PATTERNS/**)|Edit(docs/V0[23]-*.md)|Edit(docs/DFG-AGENT-LCM-SPEC.md)|Edit(docs/PHILOSOPHY-AND-HARDENING.md)|Edit(docs/DISPATCH-OPERATOR-PATTERNS.md)|Write(docs/decisions/ADR-*.md)",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/methodology-edit-guard.py", "timeout": 30 }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gh pr create *)",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/pr-review.py", "timeout": 30 },
          { "type": "command", "command": "PASSIVE=1 kit/hooks/pr-issue-reference.py", "timeout": 10 }
        ]
      },
      {
        "matcher": "mcp__scheduled-tasks__create_scheduled_task|mcp__scheduled-tasks__update_scheduled_task|CronCreate",
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/schedule-governance.py", "timeout": 10 }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=GateCheck kit/hooks/event-log.sh", "timeout": 30 }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=TaskDispatch kit/hooks/event-log.sh", "timeout": 5 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=TaskComplete kit/hooks/event-log.sh", "timeout": 5 }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=Compaction kit/hooks/event-log.sh", "timeout": 30 }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 DFG_EVENT_TYPE=Compaction kit/hooks/event-log.sh", "timeout": 30 }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          { "type": "command", "command": "PASSIVE=1 kit/hooks/event-log.sh", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "kit/hooks/stop.sh", "timeout": 30 }
        ]
      }
    ]
  }
}
